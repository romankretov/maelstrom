# ---------------------------------------------------------------------------
# Maelstrom — environment template
# Copy to .env (dev) or have infra/bootstrap.sh generate one on the VPS.
# NEVER commit .env. Real secrets live in the encrypted vault in Postgres.
# ---------------------------------------------------------------------------

# Public-facing domain
MAELSTROM_DOMAIN=maelstromhub.com
MAELSTROM_ENV=development           # development | staging | production
MAELSTROM_LOG_LEVEL=INFO

# Postgres
POSTGRES_USER=maelstrom
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=maelstrom
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://maelstrom:change-me-strong@postgres:5432/maelstrom

# Redis
REDIS_URL=redis://redis:6379/0

# API
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-me-32-random-bytes-base64
API_CORS_ORIGINS=https://maelstromhub.com
SESSION_COOKIE_DOMAIN=maelstromhub.com
SESSION_COOKIE_SECURE=true

# Frontend
NEXT_PUBLIC_API_BASE_URL=https://maelstromhub.com/api
NEXT_PUBLIC_WS_BASE_URL=wss://maelstromhub.com/ws

# Vault master key path (file containing 32 random bytes, mode 0400, root-owned)
# Used to encrypt exchange API keys at rest. Generated by bootstrap.sh.
MAELSTROM_MASTER_KEY_PATH=/run/secrets/master_key

# LLM providers (entered via the UI after first boot, NOT here — these are dev fallbacks only)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Caddy
CADDY_EMAIL=roman.kretov.02@gmail.com

# Container image tag (set by deploy workflow)
IMAGE_TAG=latest
